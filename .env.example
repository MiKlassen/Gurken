NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase's newer Vercel integration may provide this instead of/in addition to the anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 32-byte key for app-level encryption of personal content fields in public app tables.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Keep this server-side only. Never prefix with NEXT_PUBLIC_.
PERSONAL_DATA_ENCRYPTION_KEY=

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Comma-separated emails that become admin after their first verified login.
INITIAL_ADMIN_EMAILS=admin@example.com

# Vercel Cron sends this automatically as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Optional fallbacks until admin DB settings are saved. DB settings win over these values.
PAYMENT_REMINDERS_ENABLED=true
PAYMENT_REMINDER_INTERVAL_DAYS=7
PAYMENT_REMINDER_BATCH_SIZE=50
PAYMENT_REMINDER_CRON_ENABLED=true
PAYMENT_REMINDER_CRON_HOUR=8
PAYMENT_REMINDER_CRON_TIMEZONE=Europe/Berlin

# SMTP secrets stay in environment. Non-secret SMTP values can be managed in the admin settings.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_TIMEOUT_MS=15000
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Gurken Treffen <noreply@gurken.family>"
SMTP_REPLY_TO=
